    {
        "id": "069c626bb63a039c",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "parse MinIO notification",
        "func": "// 1) Parse AMQP body (Buffer -> JSON)\n let data = msg.payload;\n \n if (msg.content) {\n const text = msg.content.toString(\"utf8\");\n try {\n data = JSON.parse(text);\n } catch (e) {\n // 1ο output: raw προς debug/mqtt\n const rawMsg = { ...msg, payload: { raw: text } };\n // 2ο output: τίποτα\n return [rawMsg, null];\n }\n }\n // 2) Flat notification payload\n const rec = (data.Records && data.Records[0]) ? data.Records[0] : {};\n \n const flat = {\n event: data.EventName || rec.eventName || \"unknown\",\n objectKey: data.Key || (rec.s3 && rec.s3.object && rec.s3.object.key) || \"unknown\",\n bucket: (rec.s3 && rec.s3.bucket && rec.s3.bucket.name) || \"unknown\",\n size: (rec.s3 && rec.s3.object && rec.s3.object.size) || 0,\n eventTime: rec.eventTime || new Date().toISOString()\n };\n \n // 1ο output: raw telemetry\n const rawMsg = { ...msg, payload: flat };\n \n // 2ο output: για downstream MinIO GET (ίδιο payload)\n const dlMsg = { ...msg, payload: flat };\n \n return [rawMsg, dlMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
