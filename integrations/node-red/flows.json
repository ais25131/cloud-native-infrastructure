    {
        "id": "c28f664e20debb38",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "build_business_telemetry",
        "func": "const ev = msg.payload || {};\nconst type = ev.event_type || \"unknown\";\nconst user = (ev.user && ev.user.username) ? ev.user.username : \"unknown\";\n\n// helper: count items\nfunction countItems(items) {\n  if (!Array.isArray(items)) return 0;\n  return items.reduce((sum, it) => sum + (Number(it.qty) || 0), 0);\n}\n\nlet cartItems = 0;\nlet orderItems = 0;\n\nif (type === \"cart_add\") {\n  cartItems = countItems(ev.cart && ev.cart.items);\n}\n\nif (type === \"order_created\") {\n  orderItems = countItems(ev.order && ev.order.items);\n}\n\n// Φτιάχνουμε “μήνυμα” για να βλέπεις ακριβώς αυτό που είπες\nlet message = `Ο χρήστης ${user} έκανε event ${type}`;\n\nif (type === \"login\") {\n  message = `Ο χρήστης ${user} συνδέθηκε`;\n}\n\nif (type === \"cart_add\") {\n  message = `Ο χρήστης ${user} έβαλε στο καλάθι ${cartItems} προϊόντα`;\n}\n\nif (type === \"order_created\") {\n  message = `Ο χρήστης ${user} παρήγγειλε ${orderItems} προϊόντα`;\n}\n\nmsg.payload = {\n  username: user,\n  event_type: type,\n  cart_items: cartItems,\n  order_items: orderItems,\n  message: message,\n  // προαιρετικά κρατάς και το raw event\n};\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
