    {
        "id": "791cbca18c91ae35",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "build_minio_object",
        "func": "/**\n * Function node: build_s3_object\n * Outputs:\n *  1) HTTP response (status ok)\n *  2) Upload message for amazon s3 out (MinIO)\n */\n\nconst e = msg.event || msg.payload;\n\n// Safety: αν δεν υπάρχει event, γυρνά error στον client\nif (!e || typeof e !== \"object\") {\n  const responseMsg = {\n    ...msg,\n    statusCode: 400,\n    payload: { error: \"Missing event object\" }\n  };\n  return [responseMsg, null];\n}\n\n// timestamp safe για filename\nconst now = new Date();\nconst yyyy = now.getFullYear();\nconst mm = String(now.getMonth() + 1).padStart(2, \"0\");\nconst dd = String(now.getDate()).padStart(2, \"0\");\nconst ts = now.toISOString().replace(/[:.]/g, \"-\");\n\n// βασικά πεδία\nconst type = e.event_type || \"unknown\";\nconst user =\n  e.user?.username ||\n  e.order?.user?.username ||\n  \"anonymous\";\n\n// Key μέσα στο bucket (ΜΗΝ ξεκινάει με \"events/\")\nconst key = `${type}/${yyyy}/${mm}/${dd}/${ts}_${user}.json`;\n\n// --- Μήνυμα για upload (Output 2) ---\nconst uploadMsg = {\n  ...msg,\n  payload: JSON.stringify(e),\n  key: key,              // <-- ΣΗΜΑΝΤΙΚΟ\n  filename: key,         // <-- κρατάμε και αυτό για compatibility\n  objectKey: key,        // <-- extra (μερικά nodes το κοιτάνε)\n  s3: { key: key }       // <-- extra\n};\n// --- Μήνυμα για HTTP response (Output 1) ---\nconst responseMsg = {\n  ...msg,\n  statusCode: 200,\n  payload: { status: \"ok\" }\n};\n\nreturn [responseMsg, uploadMsg];\n",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
