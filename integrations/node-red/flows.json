    {
        "id": "4ce403a2f8a05d8a",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "build_mc_cat_command",
        "func": "const bucket = msg.minio.bucket;\nconst key = msg.minio.key;\n\nif (!bucket || !key || key === \"unknown\") {\n  node.error(\"Missing bucket/key\", msg);\n  return null;\n}\n\nconst s3path = `myminio/${bucket}/${key}`;\n\nmsg.payload =\n  `set -e; ` +\n  `export MC_HOST_myminio=\"http://ais25131:!!Ais123@minio:9000\"; ` +\n  `/data/mc cat \"${s3path}\"`;\n\nreturn msg;",
