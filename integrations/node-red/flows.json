    {
        "id": "de26b1d9be6f695e",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "normalize_object_key",
        "func": "const bucket = msg.payload.bucket;\nlet key = msg.payload.objectKey;\n\n// αφαίρεσε bucket prefix αν έρθει bucket/key\nif (key && bucket && key.startsWith(bucket + \"/\")) {\n    key = key.slice((bucket + \"/\").length);\n}\n\n// URL decode (MinIO notifications συχνά είναι encoded)\nif (key) {\n    try {\n        key = decodeURIComponent(key.replace(/\\+/g, '%20'));\n    } catch (e) {\n        // ignore\n    }\n}\n\nmsg.minio = { bucket, key };\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
