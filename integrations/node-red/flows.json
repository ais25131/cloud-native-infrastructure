    {
        "id": "3ceb81deace8706e",
        "type": "function",
        "z": "b016700d924c37ba",
        "name": "validate_wp_event",
        "func": "const expectedSecret = \"supersecret123\";\nconst receivedSecret = msg.req?.headers?.[\"x-event-secret\"];\n\n// Πάρε το payload και κάνε parse αν είναι string\nlet event = msg.payload;\n\nif (typeof event === \"string\") {\n    try { event = JSON.parse(event); } catch(e) {}\n}\n\nif (receivedSecret !== expectedSecret) {\n    msg.statusCode = 401;\n    msg.payload = { error: \"Unauthorized\" };\n    return msg;\n}\n\nif (!event || !event.event_type) {\n    msg.statusCode = 400;\n    msg.payload = { error: \"Invalid payload\" };\n    return msg;\n}\n\nmsg.statusCode = 200;\nmsg.event = event;              // κρατάμε το κανονικό event object\nmsg.payload = { status: \"ok\" }; // απάντηση\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
