        "name": "clean_json_from_stdout",
        "func": "if (typeof msg.payload !== \"string\") msg.payload = String(msg.payload || \"\");\nconst out = msg.payload.trim();\n\n// βρες το πρώτο '{'\nconst i = out.indexOf(\"{\");\nif (i === -1) {\n  node.error(\"No JSON found in exec stdout\", msg);\n  return null;\n}\n\nconst jsonText = out.slice(i).trim();\n\ntry {\n  msg.payload = JSON.parse(jsonText);\n  return msg;\n} catch (e) {\n  node.error(\"JSON parse failed. First 200 chars: \" + jsonText.slice(0,200), msg);\n  return null;\n}\n",
